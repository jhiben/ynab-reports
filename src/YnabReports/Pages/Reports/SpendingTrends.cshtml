@page
@model YnabReports.Pages.Reports.SpendingTrendsModel
@{
    ViewData["Title"] = "Spending Trends";
}

<h2 class="mb-4">Spending Trends</h2>

<form method="get" class="row mb-4 align-items-end">
    <div class="col-auto">
        <label for="BudgetId" class="form-label">Budget</label>
        <select name="BudgetId" id="BudgetId" class="form-select"
                onchange="this.form.submit()"
                @(Model.Report.Budgets.Count <= 1 ? "disabled" : "")>
            @foreach (var budget in Model.Report.Budgets)
            {
                <option value="@budget.Id" selected="@(budget.Id == Model.BudgetId)">@budget.Name</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label d-block">View</label>
        <div class="btn-group" role="group">
            <a asp-page="/Reports/SpendingTrends"
               asp-route-BudgetId="@Model.BudgetId"
               asp-route-GroupByCategory="true"
               class="btn @(Model.GroupByCategory ? "btn-primary" : "btn-outline-primary")">
                Category Groups
            </a>
            <a asp-page="/Reports/SpendingTrends"
               asp-route-BudgetId="@Model.BudgetId"
               asp-route-GroupByCategory="false"
               class="btn @(!Model.GroupByCategory ? "btn-primary" : "btn-outline-primary")">
                Subcategories
            </a>
        </div>
    </div>
</form>

@if (!Model.Report.HasData)
{
    <div class="alert alert-info">
        <strong>No trend data available.</strong> Need at least one month of spending data.
    </div>
}
else
{
    <div class="mb-4">
        <canvas id="trendsChart" style="max-height: 400px;"></canvas>
    </div>

    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th></th>
                <th>Name</th>
                @foreach (var month in Model.Report.Months)
                {
                    <th class="text-end">@month</th>
                }
                <th class="text-end">Average</th>
                <th class="text-end">Trend</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Report.Items)
            {
                <tr>
                    <td><span class="color-swatch" style="background-color: @item.Color;"></span></td>
                    <td>@item.Name</td>
                    @foreach (var amount in item.MonthlyAmounts)
                    {
                        <td class="text-end">@amount.ToString("C0")</td>
                    }
                    <td class="text-end fw-bold">@item.Average.ToString("C0")</td>
                    <td class="text-end">
                        @if (item.TrendDirection == "rising")
                        {
                            <span class="text-danger">↑ @item.Trend.ToString("F0")%</span>
                        }
                        else if (item.TrendDirection == "falling")
                        {
                            <span class="text-success">↓ @item.Trend.ToString("F0")%</span>
                        }
                        else
                        {
                            <span class="text-muted">→ stable</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    @if (Model.Report.HasData)
    {
        <script>
            const months = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Report.Months));
            const items = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.Report.Items.Select(i => new { i.Name, i.Color, i.MonthlyAmounts })));

            const ctx = document.getElementById('trendsChart').getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: months,
                    datasets: items.map(item => ({
                        label: item.Name,
                        data: item.MonthlyAmounts,
                        borderColor: item.Color,
                        backgroundColor: item.Color + '33',
                        tension: 0.3,
                        fill: false,
                        pointRadius: 4
                    }))
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    interaction: {
                        mode: 'index',
                        intersect: false
                    },
                    plugins: {
                        legend: { position: 'bottom' }
                    },
                    scales: {
                        y: { beginAtZero: true }
                    }
                }
            });
        </script>
    }
}
