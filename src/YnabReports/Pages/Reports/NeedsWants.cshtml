@page
@model YnabReports.Pages.Reports.NeedsWantsModel
@{
    ViewData["Title"] = "Needs vs Wants";
}

<h2 class="mb-4">Needs vs Wants</h2>

<form method="get" class="row mb-4 align-items-end">
    <div class="col-auto">
        <label for="BudgetId" class="form-label">Budget</label>
        <select name="BudgetId" id="BudgetId" class="form-select"
                onchange="this.form.submit()"
                @(Model.Report.Budgets.Count <= 1 ? "disabled" : "")>
            @foreach (var budget in Model.Report.Budgets)
            {
                <option value="@budget.Id" selected="@(budget.Id == Model.BudgetId)">@budget.Name</option>
            }
        </select>
    </div>
</form>

@if (!Model.Report.IsConfigured)
{
    <div class="alert alert-warning">
        <strong>Configuration needed.</strong> Map your categories to classifications (Need, Want, Savings, Debt) in
        <code>appsettings.json</code> under <code>ReportOptions.CategoryClassifications</code>.
    </div>
}

@if (!Model.Report.HasData)
{
    <div class="alert alert-info">
        <strong>No data available.</strong> No categories with targets found.
    </div>
}
else
{
    <div class="report-layout">
        <div class="chart-container">
            <canvas id="needsWantsChart"></canvas>
        </div>
        <div class="table-container">
            <!-- 50/30/20 Benchmark -->
            <div class="card mb-3">
                <div class="card-body py-2">
                    <h6 class="card-title mb-2">50/30/20 Benchmark</h6>
                    <div class="row text-center">
                        <div class="col-4">
                            <small class="text-muted">Needs (≤50%)</small>
                            <div class="fw-bold @(Model.Report.NeedsPercent > 50 ? "text-danger" : "text-success")">
                                @Model.Report.NeedsPercent.ToString("F1")%
                            </div>
                        </div>
                        <div class="col-4">
                            <small class="text-muted">Wants (≤30%)</small>
                            <div class="fw-bold @(Model.Report.WantsPercent > 30 ? "text-danger" : "text-success")">
                                @Model.Report.WantsPercent.ToString("F1")%
                            </div>
                        </div>
                        <div class="col-4">
                            <small class="text-muted">Savings/Debt (≥20%)</small>
                            <div class="fw-bold @(Model.Report.SavingsDebtPercent < 20 ? "text-danger" : "text-success")">
                                @Model.Report.SavingsDebtPercent.ToString("F1")%
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th></th>
                        <th>Classification</th>
                        <th class="text-end">Amount</th>
                        <th class="text-end">%</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Report.Items)
                    {
                        <tr>
                            <td><span class="color-swatch" style="background-color: @item.Color;"></span></td>
                            <td>
                                <strong>@item.Classification</strong>
                                <br/>
                                <small class="text-muted">
                                    @string.Join(", ", item.Categories.Select(c => c.Name))
                                </small>
                            </td>
                            <td class="text-end">@item.Amount.ToString("C2")</td>
                            <td class="text-end">@item.Percentage.ToString("F1")%</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="fw-bold">
                        <td></td>
                        <td>Total</td>
                        <td class="text-end">@Model.Report.TotalTarget.ToString("C2")</td>
                        <td class="text-end">100.0%</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
}

@section Scripts {
    @if (Model.Report.HasData)
    {
        <script>
            const chartData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.Report.Items.Select(i => new { i.Classification, i.Amount, i.Percentage, i.Color })));

            const ctx = document.getElementById('needsWantsChart').getContext('2d');
            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: chartData.map(d => d.Classification),
                    datasets: [{
                        data: chartData.map(d => d.Amount),
                        backgroundColor: chartData.map(d => d.Color),
                        borderWidth: 2,
                        borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    layout: { padding: 0 },
                    plugins: {
                        legend: { display: true, position: 'bottom' },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    const item = chartData[context.dataIndex];
                                    const amount = new Intl.NumberFormat(undefined, {
                                        style: 'currency', currency: 'EUR'
                                    }).format(item.Amount);
                                    return `${item.Classification}: ${amount} (${item.Percentage}%)`;
                                }
                            }
                        }
                    }
                }
            });
        </script>
    }
}
