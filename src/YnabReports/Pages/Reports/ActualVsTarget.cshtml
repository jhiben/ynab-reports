@page
@model YnabReports.Pages.Reports.ActualVsTargetModel
@{
    ViewData["Title"] = "Actual vs Target";
}

<h2 class="mb-4">Actual vs Target</h2>

<form method="get" class="row mb-4 align-items-end">
    <div class="col-auto">
        <label for="BudgetId" class="form-label">Budget</label>
        <select name="BudgetId" id="BudgetId" class="form-select"
                onchange="this.form.submit()"
                @(Model.Report.Budgets.Count <= 1 ? "disabled" : "")>
            @foreach (var budget in Model.Report.Budgets)
            {
                <option value="@budget.Id" selected="@(budget.Id == Model.BudgetId)">@budget.Name</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <label for="Month" class="form-label">Month</label>
        <select name="Month" id="Month" class="form-select" onchange="this.form.submit()">
            @foreach (var month in Model.Report.AvailableMonths)
            {
                var display = DateOnly.TryParseExact(month, "yyyy-MM-dd",
                    System.Globalization.CultureInfo.InvariantCulture,
                    System.Globalization.DateTimeStyles.None, out var d)
                    ? d.ToString("MMMM yyyy") : month;
                <option value="@month" selected="@(month == Model.Month)">@display</option>
            }
        </select>
    </div>
</form>

@if (!Model.Report.HasData)
{
    <div class="alert alert-info">
        <strong>No data available.</strong> No spending data found for the selected month.
    </div>
}
else
{
    <div class="report-layout">
        <div class="chart-container" style="max-width: 100%;">
            <canvas id="actualVsTargetChart"></canvas>
        </div>
        <div class="table-container">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th></th>
                        <th>Category</th>
                        <th class="text-end">Target</th>
                        <th class="text-end">Actual</th>
                        <th class="text-end">Difference</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Report.Items)
                    {
                        <tr>
                            <td><span class="color-swatch" style="background-color: @item.Color;"></span></td>
                            <td>@item.Name</td>
                            <td class="text-end">@item.TargetAmount.ToString("C2")</td>
                            <td class="text-end">@item.ActualAmount.ToString("C2")</td>
                            <td class="text-end @(item.Status == "under" ? "text-success" : "text-danger")">
                                @item.Difference.ToString("C2")
                                <small>(@item.DifferencePercent.ToString("F0")%)</small>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="fw-bold">
                        <td></td>
                        <td>Total</td>
                        <td class="text-end">@Model.Report.TotalTarget.ToString("C2")</td>
                        <td class="text-end">@Model.Report.TotalActual.ToString("C2")</td>
                        <td class="text-end @(Model.Report.TotalDifference >= 0 ? "text-success" : "text-danger")">
                            @Model.Report.TotalDifference.ToString("C2")
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
}

@section Scripts {
    @if (Model.Report.HasData)
    {
        <script>
            const chartData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.Report.Items.Take(15).Select(i => new { i.Name, i.TargetAmount, i.ActualAmount, i.Color })));

            const ctx = document.getElementById('actualVsTargetChart').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: chartData.map(d => d.Name),
                    datasets: [
                        {
                            label: 'Target',
                            data: chartData.map(d => d.TargetAmount),
                            backgroundColor: 'rgba(54, 162, 235, 0.6)',
                            borderColor: 'rgba(54, 162, 235, 1)',
                            borderWidth: 1
                        },
                        {
                            label: 'Actual',
                            data: chartData.map(d => d.ActualAmount),
                            backgroundColor: chartData.map(d =>
                                d.ActualAmount > d.TargetAmount
                                    ? 'rgba(255, 99, 132, 0.6)'
                                    : 'rgba(75, 192, 192, 0.6)'),
                            borderColor: chartData.map(d =>
                                d.ActualAmount > d.TargetAmount
                                    ? 'rgba(255, 99, 132, 1)'
                                    : 'rgba(75, 192, 192, 1)'),
                            borderWidth: 1
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    indexAxis: 'y',
                    plugins: {
                        legend: { position: 'top' }
                    },
                    scales: {
                        x: { beginAtZero: true }
                    }
                }
            });
        </script>
    }
}
